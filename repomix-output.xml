  gap: 0.6rem;
}

.workflow-list li {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  font-size: 0.95rem;
  color: var(--text-dark);
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: color var(--transition);
}

.workflow-list li:last-child {
  border-bottom: none;
}

.workflow-list li:hover {
  color: var(--green-mid);
}

.check {
  color: var(--green-cta);
  font-size: 1rem;
  flex-shrink: 0;
}

/* ===== RESULTS ===== */
.results {
  padding: 80px 0;
  background: var(--white);
}

.results-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.8rem;
  margin-top: 1rem;
}

.result-card {
  background: var(--off-white);
  border-radius: var(--radius);
  overflow: hidden;
  border: 1.5px solid var(--border);
  transition: transform var(--transition), box-shadow var(--transition);
}

.result-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-md);
}

.result-card img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  background: linear-gradient(135deg, #2d5a3e 0%, #4a8c60 100%);
}

.result-card h3 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-dark);
  padding: 18px 20px 8px;
}

.result-card p {
  font-size: 0.88rem;
  color: var(--text-mid);
  padding: 0 20px 20px;
  line-height: 1.7;
}

/* ===== PRODUCTS ===== */
.products {
  padding: 80px 0;
  background: var(--off-white);
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.4rem;
  margin-top: 1rem;
}

.product-card {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 16px;
  text-align: center;
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
}

.product-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow);
  border-color: var(--green-bright);
}

.product-card img {
  width: 100%;
  height: 160px;
  object-fit: contain;
  margin-bottom: 12px;
  background: var(--off-white);
  border-radius: 8px;
  padding: 8px;
}

.product-card p {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text-dark);
}

.products-cta {
  text-align: center;
  margin-top: 2.5rem;
}

/* ===== SCANNING ===== */
.scanning {
  padding: 80px 0;
  background: var(--white);
}

.scanning-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-top: 1rem;
}

.scanning-card {
  border-radius: var(--radius-lg);
  padding: 40px 36px;
}

.scanning-card.dark {
  background: var(--green-dark);
  color: var(--white);
}

.scanning-card.light {
  background: var(--off-white);
  border: 1.5px solid var(--border);
  color: var(--text-dark);
}

.scanning-card h3 {
  font-size: 1.3rem;
  font-weight: 800;
  margin-bottom: 0.9rem;
}

.scanning-card p {
  font-size: 0.92rem;
  line-height: 1.7;
  margin-bottom: 1.2rem;
  opacity: 0.88;
}

.scanning-card ul {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.scanning-card li {
  display: flex;
  align-items: flex-start;
  gap: 0.7rem;
  font-size: 0.9rem;
  line-height: 1.5;
}

.check-icon {
  color: var(--green-bright);
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 2px;
}

.scanning-card.light .check-icon {
  color: var(--green-mid);
}

/* ===== BLOG ===== */
.blog {
  padding: 80px 0;
  background: var(--off-white);
}

.blog-intro {
  font-size: 1rem;
  color: var(--green-mid);
  font-weight: 600;
  margin-bottom: 2rem;
  text-align: center;
}

.blog-grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: 1.5rem;
  align-items: start;
}

.blog-main img {
  width: 100%;
  height: 340px;
  object-fit: cover;
  border-radius: var(--radius);
  background: linear-gradient(135deg, #2d5a3e 0%, #4a8c60 100%);
}

.blog-label {
  font-size: 0.97rem;
  font-weight: 700;
  color: var(--text-dark);
  margin-top: 1rem;
}

.blog-side {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}

.blog-thumb img {
  width: 100%;
  height: 155px;
  object-fit: cover;
  border-radius: var(--radius);
  background: linear-gradient(135deg, #3a6e50 0%, #5aab78 100%);
}

.blog-thumb p {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-dark);
  margin-top: 0.6rem;
}

/* ===== FAQ ===== */
.faq {
  padding: 80px 0;
  background: var(--white);
}

.faq-container {
  display: flex;
  gap: 5rem;
  align-items: flex-start;
}

.faq-title {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--text-dark);
  flex: 0 0 260px;
  line-height: 1.3;
}

.faq-list {
  flex: 1;
}

.faq-item {
  border-bottom: 1.5px solid var(--border);
}

.faq-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: none;
  border: none;
  padding: 18px 0;
  cursor: pointer;
  font-family: var(--font-main);
  font-size: 0.97rem;
  font-weight: 600;
  color: var(--text-dark);
  text-align: right;
  gap: 1rem;
  transition: color var(--transition);
}

.faq-btn:hover {
  color: var(--green-mid);
}

.faq-arrow {
  font-size: 1.4rem;
  color: var(--text-light);
  transition: transform var(--transition);
  flex-shrink: 0;
}

.faq-btn[aria-expanded="true"] .faq-arrow {
  transform: rotate(90deg);
  color: var(--green-mid);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), padding 0.25s;
}

.faq-answer.open {
  max-height: 400px;
  padding-bottom: 16px;
}

.faq-answer p {
  font-size: 0.92rem;
  color: var(--text-mid);
  line-height: 1.8;
}

/* ===== CONTACT ===== */
.contact {
  padding: 80px 0;
  background: var(--off-white);
}

.contact-container {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 5rem;
  align-items: start;
}

.contact-info h2 {
  font-size: 2rem;
  font-weight: 800;
  color: var(--text-dark);
  margin-bottom: 1rem;
}

.contact-info p {
  font-size: 0.92rem;
  color: var(--text-mid);
  line-height: 1.8;
  margin-bottom: 1rem;
}

.contact-start {
  color: var(--text-dark) !important;
  font-size: 1rem !important;
}

.contact-legal {
  font-size: 0.78rem !important;
  color: var(--text-light) !important;
  line-height: 1.6 !important;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-group label {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text-dark);
}

.form-group input {
  padding: 11px 14px;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  font-family: var(--font-main);
  font-size: 0.92rem;
  color: var(--text-dark);
  background: var(--white);
  transition: border-color var(--transition), box-shadow var(--transition);
  outline: none;
}

.form-group input:focus {
  border-color: var(--green-mid);
  box-shadow: 0 0 0 3px rgba(45, 106, 79, 0.12);
}

.form-group input::placeholder {
  color: var(--text-light);
  font-size: 0.88rem;
}

.btn-submit {
  background: var(--green-cta);
  color: var(--white);
  border: none;
  padding: 14px 32px;
  border-radius: 8px;
  font-family: var(--font-main);
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  align-self: flex-start;
  transition: background var(--transition), transform var(--transition);
  margin-top: 4px;
}

.btn-submit:hover {
  background: var(--green-hover);
  transform: translateY(-2px);
}

/* ===== PRICING ===== */
.pricing-section {
  padding: 80px 0;
  background: var(--white);
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 1rem;
  align-items: start;
}

.pricing-card {
  background: var(--off-white);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 36px 30px;
  position: relative;
  transition: transform var(--transition), box-shadow var(--transition);
}

.pricing-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-md);
}

.pricing-popular {
  background: var(--green-dark);
  border-color: var(--green-mid);
  color: var(--white);
  transform: translateY(-10px);
}

.pricing-popular:hover {
  transform: translateY(-16px);
}

.pricing-badge {
  display: inline-block;
  background: var(--green-mid);
  color: var(--white);
  font-size: 0.75rem;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 20px;
  margin-bottom: 1rem;
}

.pricing-badge.popular {
  background: var(--green-bright);
  color: var(--green-dark);
}

.pricing-card h3 {
  font-size: 1.3rem;
  font-weight: 800;
  margin-bottom: 0.8rem;
}

.pricing-popular h3 {
  color: var(--white);
}

.pricing-price {
  margin-bottom: 0.8rem;
}

.price-amount {
  display: block;
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--green-cta);
  line-height: 1;
}

.pricing-popular .price-amount {
  color: var(--green-bright);
}

.price-period {
  font-size: 0.85rem;
  color: var(--text-light);
}

.pricing-popular .price-period {
  color: rgba(255, 255, 255, 0.6);
}

.pricing-desc {
  font-size: 0.9rem;
  color: var(--text-mid);
  margin-bottom: 1.4rem;
  line-height: 1.6;
}

.pricing-popular .pricing-desc {
  color: rgba(255, 255, 255, 0.75);
}

.pricing-features {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
  margin-bottom: 1.8rem;
}

.pricing-features li {
  display: flex;
  align-items: flex-start;
  gap: 0.7rem;
  font-size: 0.9rem;
  color: var(--text-dark);
}

.pricing-popular .pricing-features li {
  color: rgba(255, 255, 255, 0.85);
}

.pricing-features li.disabled {
  opacity: 0.4;
}

.pricing-features li.disabled span {
  color: #e74c3c;
}

.pricing-btn {
  display: block;
  text-align: center;
}

.pricing-popular .pricing-btn {
  border-color: var(--green-bright);
  color: var(--green-bright);
}

.pricing-popular .pricing-btn:hover {
  background: var(--green-bright);
  color: var(--green-dark);
}

/* ===== LOGIN ===== */
.login-section {
  margin-top: 68px;
  min-height: calc(100vh - 68px);
  background: var(--off-white);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 24px;
}

.login-card {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 48px 44px;
  width: 100%;
  max-width: 440px;
  box-shadow: var(--shadow-md);
  text-align: center;
}

.login-logo {
  display: inline-block;
  font-size: 2rem;
  font-weight: 900;
  color: var(--green-dark);
  margin-bottom: 1.5rem;
}

.login-card h1 {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--text-dark);
  margin-bottom: 0.4rem;
}

.login-sub {
  font-size: 0.9rem;
  color: var(--text-light);
  margin-bottom: 2rem;
}

.login-form {
  text-align: right;
}

.login-form .form-group {
  margin-bottom: 1rem;
}

.login-remember {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.4rem;
  font-size: 0.88rem;
}

.checkbox-label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  color: var(--text-mid);
}

.checkbox-label input {
  accent-color: var(--green-cta);
  width: 16px;
  height: 16px;
}

.forgot-link {
  color: var(--green-mid);
  font-size: 0.88rem;
  font-weight: 600;
}

.forgot-link:hover {
  color: var(--green-cta);
}

.login-submit {
  width: 100%;
}

.login-register {
  font-size: 0.88rem;
  color: var(--text-mid);
  margin-top: 1.5rem;
  text-align: center;
}

/* ===== FOOTER ===== */
.footer {
  background: var(--green-dark);
  color: rgba(255, 255, 255, 0.85);
}

.footer-container {
  display: flex;
  gap: 4rem;
  padding: 60px 24px 40px;
  align-items: flex-start;
}

.footer-cta {
  flex: 0 0 260px;
}

.footer-cta h3 {
  font-size: 1.2rem;
  font-weight: 800;
  color: var(--white);
  margin-bottom: 0.8rem;
  line-height: 1.4;
}

.footer-cta p {
  font-size: 0.88rem;
  line-height: 1.7;
  margin-bottom: 1.2rem;
  opacity: 0.8;
}

.btn-cta-footer {
  display: inline-block;
  background: var(--green-cta);
  color: var(--white);
  padding: 10px 28px;
  border-radius: 7px;
  font-weight: 700;
  font-size: 0.95rem;
  transition: background var(--transition);
}

.btn-cta-footer:hover {
  background: var(--green-bright);
}

.footer-links {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  flex: 1;
}

.footer-col h4 {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--white);
  margin-bottom: 1rem;
}

.footer-col ul {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.footer-col a {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.65);
  transition: color var(--transition);
}

.footer-col a:hover {
  color: var(--white);
}

.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding: 20px 24px;
}

.footer-bottom .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.footer-bottom p {
  font-size: 0.82rem;
  opacity: 0.6;
}

.footer-legal {
  display: flex;
  gap: 1.5rem;
}

.footer-legal a {
  font-size: 0.82rem;
  opacity: 0.6;
  transition: opacity var(--transition);
}

.footer-legal a:hover {
  opacity: 1;
}

/* ===== SCROLL ANIMATION ===== */
.fade-in {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}

.fade-in.visible {
  opacity: 1;
  transform: none;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .products-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .footer-links {
    grid-template-columns: repeat(2, 1fr);
  }

  .footer-container {
    flex-direction: column;
    gap: 2.5rem;
  }

  .pricing-grid {
    grid-template-columns: 1fr;
    max-width: 440px;
    margin-inline: auto;
  }

  .pricing-popular {
    transform: none;
  }

  .pricing-popular:hover {
    transform: translateY(-6px);
  }
}

@media (max-width: 820px) {

  .nav-links,
  .nav-actions .phone,
  .btn-login {
    display: none;
  }

  .mobile-menu-btn {
    display: flex;
  }

  .hero-container {
    flex-direction: column-reverse;
  }

  .hero-image-wrap {
    flex: unset;
    width: 100%;
    max-width: 100%;
  }

  .hero-content {
    text-align: center;
  }

  .hero-btns {
    justify-content: center;
  }

  .workflow-container {
    flex-direction: column;
  }

  .workflow-image {
    width: 100%;
  }

  .faq-container {
    flex-direction: column;
    gap: 1.5rem;
  }

  .faq-title {
    flex: unset;
  }

  .contact-container {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .scanning-grid {
    grid-template-columns: 1fr;
  }

  .blog-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 600px) {
  .products-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .stats-grid {
    flex-direction: column;
    align-items: center;
  }

  .results-grid {
    grid-template-columns: 1fr;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .footer-links {
    grid-template-columns: repeat(2, 1fr);
  }

  .footer-bottom .container {
    flex-direction: column;
    gap: 0.8rem;
    text-align: center;
  }

  .login-card {
    padding: 32px 24px;
  }
}

@media (max-width: 420px) {
  .products-grid {
    grid-template-columns: 1fr 1fr;
  }

  .hero-btns {
    flex-direction: column;
    align-items: center;
  }
}
