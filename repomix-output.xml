          <tr>
            <th>الاسم</th>
            <th>السعر</th>
            <th>أيام التوصيل</th>
            <th>الإجراءات</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>

    <!-- Leads Tab -->
