      <div class="tab" onclick="switchTab('leads')">العملاء المحتملين</div>
      <div class="tab" onclick="switchTab('cases')">الطلبات (Cases)</div>
    </div>

    <!-- Products Tab -->
    <div id="productsTab" class="tab-content active">
      <h3>إضافة منتج جديد</h3>
      <form id="productForm" style="max-width: 600px;">
        <div class="form-row"><input type="text" id="pName" placeholder="اسم المنتج" required></div>
        <div class="form-row"><textarea id="pDesc" placeholder="الوصف" required></textarea></div>
        <div class="form-row"><input type="number" id="pPrice" placeholder="السعر الأساسي" required></div>
        <div class="form-row"><input type="number" id="pDays" placeholder="أيام التوصيل" required></div>
        <button type="submit" class="btn-action">إضافة</button>
